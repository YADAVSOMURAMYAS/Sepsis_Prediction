# ─────────────────────────────────────────────────────────
# ML_Lab_Project — root .gitignore
# ─────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────
venv/
env/
.venv/
sepsis/

# ── SQLite database (local only, regenerated by seed) ─────
backend/*.db
*.db

# ── Environment / secrets ─────────────────────────────────
.env
.env.*
secrets.txt
*.secret

# ── Node / Frontend ───────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/

# ── OS files ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────
*.log
logs/

# ── Build artifacts ───────────────────────────────────────
build/
dist/
*.egg-info/

# ── Jupyter ───────────────────────────────────────────────
.ipynb_checkpoints/

# ── HTML screen exports (not needed in repo) ──────────────
screens_html/
